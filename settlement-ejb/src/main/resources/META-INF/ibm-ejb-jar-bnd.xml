<?xml version="1.0" encoding="UTF-8"?>
<ejb-jar-bnd xmlns="http://websphere.ibm.com/xml/ns/javaee"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://websphere.ibm.com/xml/ns/javaee
                                 http://websphere.ibm.com/xml/ns/javaee/ibm-ejb-jar-bnd_2_0.xsd"
             version="2.0">

    <message-driven name="SwiftReplyMDB">
        <!-- Activation Specification binding for IBM MQ -->
        <jca-adapter activation-spec-binding-name="jms/SwiftReplyActivationSpec"
                     destination-binding-name="jms/SwiftReplyQueue"/>
    </message-driven>

</ejb-jar-bnd>
