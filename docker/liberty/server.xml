<?xml version="1.0" encoding="UTF-8"?>
<server description="Bond Settlement System - Liberty Server">

    <!--
        Message receiving is handled by SwiftReplyMDB (Message-Driven Bean) in the
        EJB module, activated via IBM MQ Resource Adapter's JCA activation spec.
        Message sending uses Spring JmsTemplate with application-managed MQ client.
    -->
    <featureManager>
        <feature>servlet-6.0</feature>
        <feature>enterpriseBeans-4.0</feature>
        <feature>connectors-2.1</feature>
        <feature>persistence-3.1</feature>
        <feature>cdi-4.0</feature>
        <feature>beanValidation-3.0</feature>
        <feature>jdbc-4.2</feature>
        <feature>jndi-1.0</feature>
        <feature>transportSecurity-1.0</feature>
        <feature>messagingClient-3.0</feature>
        <feature>mdb-4.0</feature>
        <feature>localConnector-1.0</feature>
        <feature>concurrent-3.0</feature>
    </featureManager>

    <!-- Local user registry -->
    <basicRegistry id="basic" realm="BondSettlementRealm">
        <user name="admin" password="admin123"/>
        <user name="app" password="passw0rd"/>
    </basicRegistry>

    <!-- JTA Transaction: XA two-phase commit timeout -->
    <transaction
        totalTranLifetimeTimeout="30s"
        propogatedOrBMTTranLifetimeTimeout="30s"
        clientInactivityTimeout="10s"
        LPSHeuristicCompletion="ROLLBACK"/>

    <!-- HTTP Endpoint -->
    <httpEndpoint id="defaultHttpEndpoint"
                  httpPort="9080"
                  httpsPort="9443"
                  host="*"/>

    <!-- Oracle DataSource -->
    <library id="oracleLib">
        <fileset dir="/opt/ibm/wlp/usr/shared/resources/jdbc" includes="ojdbc11.jar"/>
    </library>

    <dataSource id="OracleDS" jndiName="jdbc/OracleDS" type="javax.sql.DataSource">
        <jdbcDriver libraryRef="oracleLib"/>
        <properties.oracle
            URL="jdbc:oracle:thin:@${env.ORACLE_HOST}:${env.ORACLE_PORT}/XEPDB1"
            user="settlement"
            password="settlement123"/>
        <connectionManager maxPoolSize="20" minPoolSize="5" connectionTimeout="30s"/>
    </dataSource>

    <!-- ==================== IBM MQ Resource Adapter ==================== -->
    <resourceAdapter id="mqJmsRa"
                     location="${server.config.dir}/resources/wmq/wmq.jakarta.jmsra.rar">
        <classloader apiTypeVisibility="spec, ibm-api, third-party"/>
    </resourceAdapter>

    <!-- JMS Queue Connection Factory (container-managed, used by MDB and JNDI lookups) -->
    <jmsQueueConnectionFactory id="swiftQueueCF"
                               jndiName="jms/SwiftQueueCF"
                               connectionManagerRef="mqConnectionManager">
        <properties.mqJmsRa
            hostName="${env.MQ_HOST}"
            port="${env.MQ_PORT}"
            channel="SETTLEMENT.SVRCONN"
            queueManager="SETTLEMENT_QM"
            transportType="CLIENT"
            userName="app"
            password="passw0rd"/>
    </jmsQueueConnectionFactory>

    <connectionManager id="mqConnectionManager" maxPoolSize="20" minPoolSize="2"/>

    <!-- JMS Queue: outgoing MT541 messages -->
    <jmsQueue id="swiftSendQueue" jndiName="jms/SwiftSendQueue">
        <properties.mqJmsRa baseQueueName="SWIFT.SEND.QUEUE"/>
    </jmsQueue>

    <!-- JMS Queue: incoming MT548 replies -->
    <jmsQueue id="swiftReplyQueue" jndiName="jms/SwiftReplyQueue">
        <properties.mqJmsRa baseQueueName="SWIFT.REPLY.QUEUE"/>
    </jmsQueue>

    <!-- JMS Activation Spec for SwiftReplyMDB -->
    <jmsActivationSpec id="jms/SwiftReplyActivationSpec">
        <properties.mqJmsRa
            hostName="${env.MQ_HOST}"
            port="${env.MQ_PORT}"
            channel="SETTLEMENT.SVRCONN"
            queueManager="SETTLEMENT_QM"
            transportType="CLIENT"
            destination="SWIFT.REPLY.QUEUE"
            destinationType="jakarta.jms.Queue"
            maxPoolDepth="5"
            userName="app"
            password="passw0rd"/>
    </jmsActivationSpec>

    <!-- ==================== Application ==================== -->
    <enterpriseApplication id="bond-settlement"
                           location="bond-settlement.ear"
                           name="bond-settlement">
        <classloader apiTypeVisibility="spec, ibm-api, third-party"/>
    </enterpriseApplication>

    <!-- Logging -->
    <logging consoleLogLevel="INFO"
             traceSpecification="com.settlement.*=fine:com.ibm.mq.*=info"/>

</server>
