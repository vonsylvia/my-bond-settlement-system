          "legendFormat": "PUT (persistent)",
          "refId": "C"
        },
        {
          "expr": "rate(ibmmq_qmgr_persistent_message_destructive_get_total[5m])",
          "legendFormat": "GET (persistent)",
          "refId": "D"
        }
