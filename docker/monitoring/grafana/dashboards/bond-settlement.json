    {
      "title": "IBM MQ - Put/Get Message Rates (QM-level)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(ibmmq_qmgr_mqput_mqput1_total[5m])",
          "legendFormat": "PUT (total)",
          "refId": "A"
        },
        {
          "expr": "rate(ibmmq_qmgr_destructive_get_total[5m])",
          "legendFormat": "GET (total)",
          "refId": "B"
        },
        {
